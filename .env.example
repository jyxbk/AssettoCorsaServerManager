# AC Server Dashboard — Configuration
# =====================================
# 1. Copy this file to .env:  cp .env.example .env
# 2. Fill in all values
# 3. Make sure .env is in .gitignore (never commit it!)
#
# Systemd service: load environment variables via EnvironmentFile=/opt/acweb/.env
# Example acweb.service:
#   [Service]
#   EnvironmentFile=/opt/acweb/.env
#   ExecStart=/opt/acweb/venv/bin/python3 /opt/acweb/app.py


# ── Required: Authentication ──────────────────────────────────────────────────

# Flask session secret — long random string, never reuse.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
ACWEB_SECRET=REPLACE_WITH_RANDOM_STRING_AT_LEAST_32_CHARS

# Login credentials for the web dashboard
ACWEB_USER=admin
ACWEB_PASS=REPLACE_WITH_SECURE_PASSWORD


# ── Optional: Server Configuration ───────────────────────────────────────────

# systemd service name of the Assetto Server (default: acserver)
# AC_SERVICE=acserver

# RCON port of the Assetto Server (default: 9700)
# AC_RCON_PORT=9700

# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
# ACWEB_LOG_LEVEL=INFO


# ── Optional: Notifications ───────────────────────────────────────────────────
# Discord and Telegram configuration is managed in the dashboard under
# "Settings → Notifications" and stored as JSON — no env var needed.


# ── Local only: Deploy script ─────────────────────────────────────────────────
# Only used by deploy.py, never read by the app server.
# Never copy this to the production server!

ACWEB_HOST=your-server-ip
ACWEB_SSH_USER=your-ssh-user
ACWEB_SSH_PASS=REPLACE_WITH_SSH_PASSWORD
ACWEB_SSH_PORT=22
ACWEB_REMOTE_PATH=/opt/acweb