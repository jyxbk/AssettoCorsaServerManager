# AC Server Dashboard — Konfiguration
# =========================================
# 1. Diese Datei nach .env kopieren:  cp .env.example .env
# 2. Alle Werte befüllen
# 3. Sicherstellen dass .env in .gitignore steht (nie committen!)
#
# Systemd-Service: Umgebungsvariablen via EnvironmentFile=/opt/acweb/.env laden
# Beispiel acweb.service:
#   [Service]
#   EnvironmentFile=/opt/acweb/.env
#   ExecStart=/opt/acweb/venv/bin/python3 /opt/acweb/app.py


# ── Pflicht: Authentifizierung ────────────────────────────────────────────────

# Flask-Session-Secret — langer zufälliger String, niemals wiederverwenden.
# Generieren: python3 -c "import secrets; print(secrets.token_hex(32))"
ACWEB_SECRET=HIER_ZUFAELLIGEN_STRING_EINTRAGEN_MINDESTENS_32_ZEICHEN

# Login-Zugangsdaten für das Web-Dashboard
ACWEB_USER=admin
ACWEB_PASS=HIER_SICHERES_PASSWORT_EINTRAGEN


# ── Optional: Server-Konfiguration ───────────────────────────────────────────

# systemd-Service-Name des Assetto-Servers (default: acserver)
# AC_SERVICE=acserver

# RCON-Port des Assetto-Servers (default: 9700)
# AC_RCON_PORT=9700

# Log-Level: DEBUG | INFO | WARNING | ERROR (default: INFO)
# ACWEB_LOG_LEVEL=INFO


# ── Optional: Benachrichtigungen ──────────────────────────────────────────────
# Discord- und Telegram-Konfiguration wird im Dashboard unter
# "Einstellungen → Benachrichtigungen" konfiguriert und als JSON gespeichert.
# Kein Env-Var erforderlich.


# ── Nur lokal: Deploy-Script ──────────────────────────────────────────────────
# Wird nur von deploy.py genutzt, nie vom App-Server gelesen.
# Niemals auf den Produktions-Server kopieren!

ACWEB_HOST=192.168.1.71
ACWEB_SSH_USER=root
ACWEB_SSH_PASS=HIER_SSH_PASSWORT_EINTRAGEN
ACWEB_SSH_PORT=22
ACWEB_REMOTE_PATH=/opt/acweb
