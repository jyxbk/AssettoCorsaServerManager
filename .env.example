# AC Server Dashboard — Pflicht-Umgebungsvariablen
# Kopiere diese Datei nach .env und fülle die Werte aus.
# .env wird NICHT in Git committed (siehe .gitignore).

# Flask session secret — zufälliger langer String, z.B.:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
ACWEB_SECRET=HIER_ZUFAELLIGEN_STRING_EINTRAGEN

# Login-Zugangsdaten für das Web-Dashboard
ACWEB_USER=admin
ACWEB_PASS=HIER_SICHERES_PASSWORT_EINTRAGEN

# Deploy-Script (deploy.py) — nur lokal benötigt, nie committen
ACWEB_HOST=192.168.1.71
ACWEB_SSH_USER=root
ACWEB_SSH_PASS=HIER_SSH_PASSWORT_EINTRAGEN
ACWEB_SSH_PORT=22
ACWEB_REMOTE_PATH=/opt/acweb
